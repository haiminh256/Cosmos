{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "CMake: 1. Clean Cache (Chỉ chạy khi lỗi hoặc đổi cấu trúc)",
            "command": "cmd",
            "args": [
                "/c",
                "if exist ${workspaceFolder}\\bin rmdir /s /q ${workspaceFolder}\\bin"
            ],
            "problemMatcher": [],
            "detail": "Xóa sạch thư mục build cũ để dọn dẹp bộ nhớ đệm."
        },
        {
            "type": "shell",
            "label": "CMake: 2. Configure Project",
            "command": "cmake",
            "args": [
                "-G", "MinGW Makefiles",
                "-DCMAKE_CXX_COMPILER=C:/mingw64/bin/g++.exe",
                "-DCMAKE_MAKE_PROGRAM=C:/mingw64/bin/mingw32-make.exe",
                "-B", "${workspaceFolder}\\bin",
                "-S", "${workspaceFolder}"
            ],
            "problemMatcher": [
                "$gcc"
            ],
            "dependsOn": [
                "CMake: 1. Clean Cache (Chỉ chạy khi lỗi hoặc đổi cấu trúc)"
            ],
            "detail": "Quét cấu hình 2 file CMakeLists.txt và ép sử dụng bộ dịch MinGW GCC."
        },
        {
            "type": "shell",
            "label": "CMake: 3. Build Project (Internal)",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}\\bin"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Biên dịch nội bộ các file .cpp thay đổi thông qua CMake."
        },
        {
            "type": "shell",
            "label": "CMake: Build & Run Game",
            "command": "cmd",
            "args": [
                "/c",
                // Chạy trực tiếp file exe cứng từ thư mục bin sau khi luồng build của task 3 đã kết thúc hoàn toàn
                "${workspaceFolder}\\bin\\main.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            // ÉP BUỘC: Phải chạy xong lệnh Build (Task 3) thành công thì mới kích hoạt lệnh mở file exe này
            "dependsOn": [
                "CMake: 3. Build Project (Internal)"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Kích hoạt biên dịch 1 giây và TỰ ĐỘNG KHỞI CHẠY game ngay lập tức."
        }
    ]
}
